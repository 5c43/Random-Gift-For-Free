rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.uid == 'ywskXjtxYJVD5xSU5wSNcpaWnXZ2' || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "abdulla59868@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'username', 'displayName', 'photoURL', 'bio', 'role', 'isVerifiedSeller', 'balance', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.role in ['user', 'admin'] &&
             data.isVerifiedSeller is bool &&
             (!('balance' in data) || data.balance is number) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 50)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000));
    }

    function isValidListing(data) {
      return hasOnlyAllowedFields(['sellerId', 'sellerName', 'sellerUsername', 'title', 'description', 'price', 'game', 'category', 'device', 'deliveryTime', 'level', 'rank', 'region', 'skins', 'images', 'status', 'createdAt']) &&
             data.sellerId is string &&
             data.sellerName is string && data.sellerName.size() <= 50 &&
             data.sellerUsername is string && (data.sellerUsername.size() == 0 || (data.sellerUsername.size() >= 3 && data.sellerUsername.size() <= 20)) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() <= 5000 &&
             data.price is number && data.price >= 0 &&
             data.game is string && data.game.size() <= 50 &&
             (!('category' in data) || (data.category is string && data.category.size() <= 50)) &&
             (!('device' in data) || (data.device is string && data.device.size() <= 50)) &&
             (!('deliveryTime' in data) || (data.deliveryTime is string && data.deliveryTime.size() <= 50)) &&
             (!('level' in data) || (data.level is string && data.level.size() <= 50)) &&
             (!('rank' in data) || (data.rank is string && data.rank.size() <= 50)) &&
             (!('region' in data) || (data.region is string && data.region.size() <= 50)) &&
             (!('skins' in data) || (data.skins is string && data.skins.size() <= 1000)) &&
             (!('images' in data) || (data.images is list && data.images.size() <= 7)) &&
             data.status in ['active', 'sold', 'pending'];
    }

    function isValidPurchase(data) {
      return hasOnlyAllowedFields(['listingId', 'buyerId', 'sellerId', 'price', 'receiptEmail', 'status', 'createdAt']) &&
             data.listingId is string &&
             data.buyerId is string &&
             data.sellerId is string &&
             data.price is number &&
             data.receiptEmail is string &&
             data.status in ['awaiting_payment', 'Pending Delivery', 'completed', 'refunded'];
    }

    function isValidChat(data) {
      return hasOnlyAllowedFields(['listingId', 'buyerId', 'sellerId', 'lastMessage', 'lastMessageAt', 'createdAt']) &&
             data.listingId is string &&
             data.buyerId is string &&
             data.sellerId is string &&
             (!('lastMessage' in data) || (data.lastMessage is string && data.lastMessage.size() <= 1000));
    }

    function isValidMessage(data) {
      return hasOnlyAllowedFields(['chatId', 'senderId', 'text', 'createdAt']) &&
             data.chatId is string &&
             data.senderId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 2000;
    }

    function isValidReview(data) {
      return hasOnlyAllowedFields(['sellerId', 'buyerId', 'buyerName', 'rating', 'comment', 'createdAt']) &&
             data.sellerId is string &&
             data.buyerId is string &&
             data.buyerName is string && data.buyerName.size() <= 50 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000;
    }

    function isValidSellerApplication(data) {
      return hasOnlyAllowedFields(['uid', 'username', 'photoURL', 'bio', 'platformLink', 'reviewCount', 'telegram', 'discord', 'status', 'rejectionReason', 'processedAt', 'createdAt']) &&
             data.uid is string &&
             data.username is string &&
             data.bio is string && data.bio.size() <= 2000 &&
             data.platformLink is string && data.platformLink.size() <= 500 &&
             data.reviewCount is number && data.reviewCount >= 30 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('telegram' in data) || (data.telegram is string && data.telegram.size() <= 100)) &&
             (!('discord' in data) || (data.discord is string && data.discord.size() <= 100)) &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('rejectionReason' in data) || (data.rejectionReason is string && data.rejectionReason.size() <= 1000)) &&
             (!('processedAt' in data) || data.processedAt is timestamp);
    }

    function isValidWithdrawal(data) {
      return hasOnlyAllowedFields(['uid', 'amount', 'walletAddress', 'status', 'rejectionReason', 'processedAt', 'createdAt']) &&
             data.uid is string &&
             data.amount is number && data.amount > 0 &&
             data.walletAddress is string && data.walletAddress.size() > 0 &&
             data.status in ['pending', 'approved', 'rejected', 'completed'] &&
             (!('rejectionReason' in data) || (data.rejectionReason is string && data.rejectionReason.size() <= 1000)) &&
             (!('processedAt' in data) || data.processedAt is timestamp);
    }

    function isValidNotification(data) {
      return hasOnlyAllowedFields(['uid', 'title', 'message', 'type', 'link', 'read', 'createdAt']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 500 &&
             data.type in ['sale', 'purchase', 'message', 'system'] &&
             (!('link' in data) || (data.link is string && data.link.size() <= 500)) &&
             data.read is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (request.resource.data.role == 'user' || isAdmin()) &&
                    request.resource.data.isVerifiedSeller == false &&
                    (!('balance' in request.resource.data) || request.resource.data.balance == 0) &&
                    getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.username)).data.uid == userId;
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) &&
                        request.resource.data.role == resource.data.role &&
                        request.resource.data.isVerifiedSeller == resource.data.isVerifiedSeller &&
                        request.resource.data.username == resource.data.username &&
                        request.resource.data.balance <= resource.data.balance) ||
                       (isAuthenticated() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']) &&
                        request.resource.data.balance > resource.data.balance) ||
                       isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    request.resource.data.uid == request.auth.uid &&
                    username.size() >= 3 && username.size() <= 20;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidListing(request.resource.data) &&
                    request.resource.data.sellerId == request.auth.uid &&
                    (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerifiedSeller == true));
      allow update: if (isAuthenticated() && isValidListing(request.resource.data) &&
                        resource.data.sellerId == request.auth.uid &&
                        request.resource.data.sellerId == resource.data.sellerId) ||
                       (isAuthenticated() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                        request.resource.data.status == 'sold' &&
                        resource.data.status == 'pending' &&
                        getAfter(/databases/$(database)/documents/purchases/$(request.auth.uid + '_' + listingId)).data.status == 'completed') ||
                       isAdmin();
      allow delete: if (isAuthenticated() && resource.data.sellerId == request.auth.uid) || isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidChat(request.resource.data) &&
                    (request.resource.data.buyerId == request.auth.uid || request.resource.data.sellerId == request.auth.uid);
      allow update: if isAuthenticated() && isValidChat(request.resource.data) &&
                    (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid) &&
                    request.resource.data.buyerId == resource.data.buyerId &&
                    request.resource.data.sellerId == resource.data.sellerId &&
                    request.resource.data.listingId == resource.data.listingId;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() &&
                  (get(/databases/$(database)/documents/chats/$(chatId)).data.buyerId == request.auth.uid ||
                   get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId == request.auth.uid ||
                   isAdmin());
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) &&
                    request.resource.data.senderId == request.auth.uid &&
                    request.resource.data.chatId == chatId &&
                    (get(/databases/$(database)/documents/chats/$(chatId)).data.buyerId == request.auth.uid ||
                     get(/databases/$(database)/documents/chats/$(chatId)).data.sellerId == request.auth.uid);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) &&
                    request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPurchase(request.resource.data) &&
                    request.resource.data.buyerId == request.auth.uid;
      allow update: if (isAuthenticated() && isValidPurchase(request.resource.data) &&
                        resource.data.buyerId == request.auth.uid &&
                        request.resource.data.buyerId == resource.data.buyerId &&
                        request.resource.data.sellerId == resource.data.sellerId &&
                        request.resource.data.listingId == resource.data.listingId &&
                        request.resource.data.status == 'completed' &&
                        resource.data.status == 'Pending Delivery') ||
                       isAdmin();
    }

    match /seller_applications/{applicationId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSellerApplication(request.resource.data) &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidSellerApplication(request.resource.data);
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data) &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidWithdrawal(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAdmin(); // Only system/admin can create notifications
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']) &&
                    request.resource.data.read == true;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
